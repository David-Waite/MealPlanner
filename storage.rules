rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Recipe photos
    // Public read (needed for global recipes visible to non-authenticated users)
    // Only the recipe owner can write — path must include their uid
    match /recipes/{userId}/{recipeId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
