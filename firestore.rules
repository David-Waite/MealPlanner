rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ── Global Ingredients ───────────────────────────────────────────────────
    // Anyone can read; only admins can write (via the admin approval flow).

    match /globalIngredients/{ingredientId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Users ────────────────────────────────────────────────────────────────
    // Profiles are publicly readable (username uniqueness checks, friend search).
    // Only the account owner can write their own profile document.

    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);

      // Recipes subcollection
      match /recipes/{recipeId} {
        allow read, write: if isOwner(userId);

        // Friends listed in sharedWith can read
        allow read: if isSignedIn()
          && resource.data.get("sharedWith", []).hasAny([request.auth.uid]);

        // Admin can read any recipe (needed for pending-review queries)
        allow read: if isAdmin();
      }

      // Plan subcollection
      match /plan/{instanceId} {
        allow read, write: if isOwner(userId);
      }

      // Shopping lists subcollection
      match /shoppingLists/{listId} {
        allow read, write: if isOwner(userId);
      }

      // Snacks subcollection
      match /snacks/{snackId} {
        allow read, write: if isOwner(userId);
      }

      // Local ingredients — user-created, not yet promoted to global
      match /localIngredients/{ingredientId} {
        allow read, write: if isOwner(userId);
        // Admin can read (needed during recipe review to inspect submitted ingredients)
        allow read: if isAdmin();
      }
    }

    // ── Collection-group query: recipes across all users ─────────────────────
    // Required for loadFriendsRecipes (array-contains query on sharedWith)
    // and for the admin pending-review query.

    match /{path=**}/recipes/{recipeId} {
      allow read: if isSignedIn()
        && resource.data.get("sharedWith", []).hasAny([request.auth.uid]);
      allow read: if isAdmin();
    }

    // ── Collection-group query: localIngredients across all users ─────────────
    // Required for the admin pending-snack-review query.

    match /{path=**}/localIngredients/{ingredientId} {
      allow read: if isAdmin();
    }

    // ── Global Recipes ────────────────────────────────────────────────────────
    // Approved recipes are publicly readable; only admins write here.

    match /globalRecipes/{recipeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Friendships ───────────────────────────────────────────────────────────
    // Both participants can read and update; creator must be a participant.

    match /friendships/{friendshipId} {
      allow read, update: if isSignedIn()
        && resource.data.userIds.hasAny([request.auth.uid]);

      allow create: if isSignedIn()
        && request.resource.data.userIds.hasAny([request.auth.uid]);
    }

  }
}
